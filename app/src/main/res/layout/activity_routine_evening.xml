<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="32dp"
        android:paddingTop="48dp"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentStart="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ESTI REGENERÁLÁS"
                android:textColor="@color/deep_pink"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/tvRoutineTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Esti Rutin"
                android:textColor="@color/slate_800"
                android:textSize="32sp"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvRoutineSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 lépés • 0 perc összesen"
                android:textColor="@color/slate_400"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnSelectProduct"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/circle_pink_full"
            android:backgroundTint="@color/soft_pink"
            android:src="@android:drawable/ic_input_add"
            app:tint="@color/deep_pink"
            android:contentDescription="Hozzáadás" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar">

        <LinearLayout
            android:id="@+id/routineContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp" />
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Actions -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@color/cream"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnCompleteRoutine"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="12dp"
            android:text="Rutin befejezése"
            android:textAllCaps="false"
            android:backgroundTint="@color/deep_pink"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:visibility="gone"
            app:cornerRadius="24dp" />

            <Button
                android:id="@+id/btnGenerateRoutine"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Rutin generálása a polcomról"
                android:textAllCaps="false"
                android:backgroundTint="@color/slate_300"
                android:textColor="@color/slate_800"
                android:textStyle="bold"
                app:cornerRadius="24dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>