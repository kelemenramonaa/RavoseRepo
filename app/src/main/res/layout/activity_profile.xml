<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDFBF9">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:scrollbarThumbVertical="@null"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavCard">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="40dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="Profilom"
                    android:textColor="#1A1616"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginBottom="30dp">

                <FrameLayout
                    android:layout_width="112dp"
                    android:layout_height="112dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/circle_pink_full"
                        android:alpha="0.3" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="106dp"
                        android:layout_height="106dp"
                        android:layout_gravity="center"
                        app:cardCornerRadius="53dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:id="@+id/profileImage"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_person"
                            android:scaleType="centerCrop" />
                    </androidx.cardview.widget.CardView>

                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/btnChangePhoto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|end"
                        android:src="@android:drawable/ic_menu_camera"
                        app:fabSize="mini"
                        app:backgroundTint="#F2C2C2"
                        app:tint="@android:color/white"
                        app:borderWidth="2dp"
                        android:contentDescription="Profilkép módosítása" />
                </FrameLayout>

                <TextView
                    android:id="@+id/profileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kovács Elena"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:textColor="#1A1616" />

                <TextView
                    android:id="@+id/profileEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="elena.kovacs@pelda.hu"
                    android:textColor="#8E8A8A"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bőrtípus beállítása"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#8E8A8A"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="16dp"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:layout_marginBottom="30dp">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDry"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_columnWeight="1"
                    android:text="Száraz"
                    android:layout_margin="6dp"
                    app:cornerRadius="16dp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOily"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_columnWeight="1"
                    android:text="Zsíros"
                    android:layout_margin="6dp"
                    app:cornerRadius="16dp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCombo"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_columnWeight="1"
                    android:text="Kombinált"
                    android:layout_margin="6dp"
                    app:cornerRadius="16dp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSensitive"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_columnWeight="1"
                    android:text="Érzékeny"
                    android:layout_margin="6dp"
                    app:cornerRadius="16dp" />
            </GridLayout>

            <!-- Személyes adatok szekció -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Személyes adatok"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#8E8A8A"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="16dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="30dp">

                <RelativeLayout
                    android:id="@+id/btnEditProfile"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:paddingHorizontal="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Adatok módosítása"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#334155" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Értesítések kezelése"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#8E8A8A"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="16dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="30dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="4dp">

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="72dp" android:paddingHorizontal="16dp">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reggeli rutin emlékeztető" android:textStyle="bold" android:textSize="14sp" android:textColor="#334155" />
                            <TextView
                                android:id="@+id/tvMorningTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="08:00"
                                android:textSize="12sp"
                                android:textColor="#64748B"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true" />
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchMorning"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:checked="true"
                            app:thumbTint="@color/powder_pink"
                            app:trackTint="@color/soft_pink" />
                    </RelativeLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F8FAFC" android:layout_marginHorizontal="16dp" />
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="72dp" android:paddingHorizontal="16dp">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Esti rutin emlékeztető" android:textStyle="bold" android:textSize="14sp" android:textColor="#334155" />
                            <TextView
                                android:id="@+id/tvEveningTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="20:00"
                                android:textSize="12sp"
                                android:textColor="#64748B"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true" />
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchEvening"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:checked="true"
                            app:thumbTint="@color/powder_pink"
                            app:trackTint="@color/soft_pink" />
                    </RelativeLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogout"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kijelentkezés"
                    android:textColor="#F87171"
                    app:strokeColor="#F87171"
                    app:strokeWidth="1dp"
                    app:cornerRadius="20dp"
                    android:paddingHorizontal="32dp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnDeleteAccount"
                    style="?attr/borderlessButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Fiók törlése"
                    android:textColor="#333333"
                    android:textSize="10sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Új Nav Bar kártyával -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNavCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="30dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@android:color/white"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:gravity="center">

            <!-- Főoldal -->
            <LinearLayout
                android:id="@+id/navHomeLayout"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView
                    android:id="@+id/ivNavHome"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_home"
                    app:tint="@color/slate_400" />
                <TextView
                    android:id="@+id/tvNavHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Főoldal"
                    android:textSize="10sp"
                    android:textColor="@color/slate_400"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Termékek -->
            <LinearLayout
                android:id="@+id/navProductsLayout"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView
                    android:id="@+id/ivNavProducts"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_spa"
                    app:tint="@color/slate_400" />
                <TextView
                    android:id="@+id/tvNavProducts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Termékek"
                    android:textSize="10sp"
                    android:textColor="@color/slate_400"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Statisztika -->
            <LinearLayout
                android:id="@+id/navStatsLayout"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView
                    android:id="@+id/ivNavStats"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_fire"
                    app:tint="@color/slate_400" />
                <TextView
                    android:id="@+id/tvNavStats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Statisztika"
                    android:textSize="10sp"
                    android:textColor="@color/slate_400"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Profil -->
            <LinearLayout
                android:id="@+id/navProfileLayout"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView
                    android:id="@+id/ivNavProfile"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_person"
                    app:tint="@color/deep_pink" />
                <TextView
                    android:id="@+id/tvNavProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profil"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/deep_pink"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>