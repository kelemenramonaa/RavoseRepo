<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="@color/slate_800" />
            </RelativeLayout>

            <LinearLayout
                android:id="@+id/headerGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_gravity="center"
                android:layout_marginTop="40dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/deep_pink"
                    android:textSize="48sp"
                    android:fontFamily="serif"
                    android:textStyle="italic"
                    android:letterSpacing="0.2" />

                <View
                    android:layout_width="40dp"
                    android:layout_height="1dp"
                    android:background="@color/powder_pink"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Elfelejtett jelszó"
                android:layout_gravity="center"
                android:layout_marginTop="32dp"
                android:textSize="28sp"
                android:textColor="@color/slate_800"
                android:fontFamily="serif" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Add meg a regisztrált e-mail címedet a jelszavad visszaállításához."
                android:gravity="center"
                android:textColor="@color/slate_500"
                android:layout_marginTop="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="40dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="E-MAIL CÍM"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/slate_400"
                    android:letterSpacing="0.1"
                    android:layout_marginStart="4dp" />

                <EditText
                    android:id="@+id/emailInput"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/edittext_rounded_white"
                    android:hint="pelda@email.com"
                    android:paddingHorizontal="16dp"
                    android:inputType="textEmailAddress"
                    android:importantForAutofill="no" />

                <Button
                    android:id="@+id/btnResetPassword"
                    android:layout_width="match_parent"
                    android:layout_height="65dp"
                    android:layout_marginTop="32dp"
                    android:text="Jelszó visszaállítása"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/powder_pink"
                    android:textColor="@color/slate_800"
                    android:textStyle="bold"
                    app:cornerRadius="12dp" />
            </LinearLayout>


            <LinearLayout
                android:id="@+id/resetSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ÚJ JELSZÓ"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/slate_400"
                    android:letterSpacing="0.1"
                    android:layout_marginStart="4dp" />

                <EditText
                    android:id="@+id/newPasswordInput"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/edittext_rounded_white"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:paddingHorizontal="16dp"
                    android:importantForAutofill="no" />

                <Button
                    android:id="@+id/btnSaveNewPassword"
                    android:layout_width="match_parent"
                    android:layout_height="65dp"
                    android:layout_marginTop="16dp"
                    android:text="Mentés"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/deep_pink"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    app:cornerRadius="12dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>