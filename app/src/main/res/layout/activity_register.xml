<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingBottom="40dp">

            <!-- Ravose Fejléc -->
            <LinearLayout
                android:id="@+id/headerGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_gravity="center"
                android:layout_marginTop="60dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/deep_pink"
                    android:textSize="48sp"
                    android:fontFamily="serif"
                    android:textStyle="italic"
                    android:letterSpacing="0.2" />

                <View
                    android:layout_width="40dp"
                    android:layout_height="1dp"
                    android:background="@color/powder_pink"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="serif"
                android:text="Regisztráció"
                android:textColor="@color/slate_800"
                android:textSize="28sp" />

            <TextView
                android:layout_width="260dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="Kezdd el a tudatos bőrápolást és érd el álmaid bőrét."
                android:textColor="@color/slate_500"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:orientation="vertical">

                <!-- Vezetéknév -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:fontFamily="serif"
                    android:letterSpacing="0.1"
                    android:text="VEZETÉKNÉV"
                    android:textColor="@color/slate_400"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/regSurname"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_rounded_pink"
                    android:hint="Kovács"
                    android:inputType="textPersonName"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp"
                    android:importantForAutofill="no" />

                <!-- Keresztnév -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="20dp"
                    android:fontFamily="serif"
                    android:letterSpacing="0.1"
                    android:text="KERESZTNÉV"
                    android:textColor="@color/slate_400"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/regFirstName"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_rounded_pink"
                    android:hint="Anna"
                    android:inputType="textPersonName"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp"
                    android:importantForAutofill="no" />

                <!-- Becenév -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="20dp"
                    android:fontFamily="serif"
                    android:letterSpacing="0.1"
                    android:text="BECENÉV"
                    android:textColor="@color/slate_400"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/regNickname"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_rounded_pink"
                    android:hint="Ancsi"
                    android:inputType="textPersonName"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp"
                    android:importantForAutofill="no" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="20dp"
                    android:fontFamily="serif"
                    android:letterSpacing="0.1"
                    android:text="E-MAIL CÍM"
                    android:textColor="@color/slate_400"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/regEmail"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_rounded_pink"
                    android:hint="pelda@email.hu"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp"
                    android:importantForAutofill="no" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="20dp"
                    android:fontFamily="serif"
                    android:letterSpacing="0.1"
                    android:text="JELSZÓ"
                    android:textColor="@color/slate_400"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/regPass"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_rounded_pink"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp"
                    android:importantForAutofill="no" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="20dp"
                    android:fontFamily="serif"
                    android:letterSpacing="0.1"
                    android:text="JELSZÓ MEGERŐSÍTÉSE"
                    android:textColor="@color/slate_400"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/regPassConfirm"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_rounded_pink"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp"
                    android:importantForAutofill="no" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <CheckBox
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/powder_pink" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Elfogadom a Feltételeket és az Adatvédelmet."
                        android:textColor="@color/slate_500"
                        android:textSize="11sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnRegisterSubmit"
                    android:layout_width="match_parent"
                    android:layout_height="65dp"
                    android:layout_marginTop="32dp"
                    android:backgroundTint="@color/powder_pink"
                    android:fontFamily="serif"
                    android:text="Regisztráció"
                    android:textAllCaps="false"
                    android:textColor="@color/slate_800"
                    android:textStyle="bold"
                    app:cornerRadius="12dp" />

                <TextView
                    android:id="@+id/btnLoginLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="32dp"
                    android:text="Már van fiókod? Belépés"
                    android:textColor="@color/slate_400"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>