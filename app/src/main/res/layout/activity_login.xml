<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp">

            <LinearLayout
                android:id="@+id/headerGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_gravity="center"
                android:layout_marginTop="60dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/deep_pink"
                    android:textSize="48sp"
                    android:fontFamily="serif"
                    android:textStyle="italic"
                    android:letterSpacing="0.2" />

                <View
                    android:layout_width="40dp"
                    android:layout_height="1dp"
                    android:background="@color/powder_pink"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bejelentkezés"
                android:layout_gravity="center"
                android:layout_marginTop="32dp"
                android:textSize="28sp"
                android:textColor="@color/slate_800"
                android:fontFamily="serif" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Üdvözöljük újra a Ravose-ban"
                android:layout_gravity="center"
                android:textColor="@color/slate_500"
                android:layout_marginTop="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="40dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="E-MAIL CÍM"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/slate_400"
                    android:letterSpacing="0.1"
                    android:layout_marginStart="4dp" />

                <EditText
                    android:id="@+id/emailInput"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/edittext_rounded_white"
                    android:hint="pelda@email.com"
                    android:paddingHorizontal="16dp"
                    android:inputType="textEmailAddress"
                    android:importantForAutofill="no" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="JELSZÓ"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/slate_400"
                    android:letterSpacing="0.1"
                    android:layout_marginStart="4dp" />

                <EditText
                    android:id="@+id/passwordInput"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/edittext_rounded_white"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:paddingHorizontal="16dp"
                    android:importantForAutofill="no" />

                <TextView
                    android:id="@+id/forgotPasswordText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:text="Elfelejtette a jelszót?"
                    android:textColor="@color/slate_400"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/loginButton"
                    android:layout_width="match_parent"
                    android:layout_height="65dp"
                    android:layout_marginTop="24dp"
                    android:text="Bejelentkezés"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/powder_pink"
                    android:textColor="@color/slate_800"
                    android:textStyle="bold"
                    app:cornerRadius="12dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnRegisterLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="40dp"
                android:text="Még nincs fiókod? Regisztráció"
                android:textColor="@color/slate_400" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>