<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/cream"
        app:layout_constraintTop_toTopOf="parent">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingEnd="16dp">
            <TextView
                android:id="@+id/btnCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="Mégse"
                android:textColor="@color/deep_pink"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Termék hozzáadása"
                android:textColor="@color/slate_800"
                android:textStyle="bold"
                android:textSize="18sp" />
        </RelativeLayout>
    </androidx.appcompat.widget.Toolbar>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/bottomButtonContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/photoCard"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/soft_pink">
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView android:id="@+id/productImageView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_product_bottle"
                        android:scaleType="centerCrop" />

                    <LinearLayout
                        android:id="@+id/photoOverlay"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:background="#1A000000">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_camera"
                            app:tint="@android:color/white" />
                        <TextView
                            android:id="@+id/tvPhotoLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fotó készítése"
                            android:layout_marginTop="8dp"
                            android:textStyle="bold"
                            android:textColor="@android:color/white"/>
                    </LinearLayout>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TERMÉK NEVE"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/slate_400"
                android:layout_marginTop="20dp"
                android:letterSpacing="0.1"/>

            <EditText
                android:id="@+id/editProductName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="4dp"
                android:hint="pl. C-Firma Fresh Serum"
                android:paddingHorizontal="16dp"
                android:textSize="14sp"
                android:background="@drawable/edittext_rounded_white"
                android:inputType="textCapSentences" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TÍPUS"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/slate_400"
                android:layout_marginTop="16dp"
                android:letterSpacing="0.1"/>

            <Spinner
                android:id="@+id/spinnerType"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/edittext_rounded_white"
                android:paddingHorizontal="12dp" />

            <LinearLayout
                android:id="@+id/layoutExpiry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:padding="12dp"
                android:background="@drawable/edittext_rounded_white"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LEJÁRATI DÁTUM"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/slate_400"
                    android:letterSpacing="0.1"/>
                <TextView
                    android:id="@+id/tvExpiryDisplay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nincs megadva"
                    android:textColor="@color/deep_pink"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AKTÍV ÖSSZETEVŐK"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/slate_400"
                android:layout_marginTop="20dp"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/tvIngredientsSelector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="50dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/edittext_rounded_white"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:text="Válassz összetevőket..."
                android:textSize="14sp"
                android:textColor="@color/slate_800"
                android:gravity="center_vertical"
                app:drawableEndCompat="@android:drawable/arrow_down_float"
                app:drawableTint="@color/slate_400" />

            <TextView
                android:id="@+id/btnAddCustomIngredient"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ Egyéni összetevő hozzáadása"
                android:textColor="@color/deep_pink"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MEGJEGYZÉS (OPCIONÁLIS)"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/slate_400"
                android:layout_marginTop="20dp"
                android:letterSpacing="0.1"/>

            <EditText
                android:id="@+id/editNote"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginTop="4dp"
                android:gravity="top"
                android:hint="Személyes tapasztalatok, illat, állag..."
                android:padding="16dp"
                android:textSize="14sp"
                android:background="@drawable/edittext_rounded_white"
                android:inputType="textMultiLine" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <FrameLayout
        android:id="@+id/bottomButtonContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:background="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent">
        <Button
            android:id="@+id/btnSaveProduct"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Mentés"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="16sp"
            android:backgroundTint="@color/powder_pink"
            android:textColor="@android:color/white"
            app:cornerRadius="12dp" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
