<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardCornerRadius="32dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center">

        <!-- Exclamation Icon -->
        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/circle_pink_full"
            android:backgroundTint="#FCECEC">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="!"
                android:textColor="@color/deep_pink"
                android:textSize="40sp"
                android:textStyle="bold" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Kompatibilitási\nfigyelmeztetés"
            android:textColor="#1E293B"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/edittext_rounded_white"
            android:backgroundTint="#FFF5F5"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:text="ÖSSZETEVŐ ÜTKÖZÉS"
            android:textColor="@color/deep_pink"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/tvConflictMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="A Vitamin C és a Retinol egyidejű használata irritációt okozhat. Javasoljuk, hogy külön napszakban alkalmazd őket."
            android:textColor="#64748B"
            android:textSize="15sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

        <Button
            android:id="@+id/btnGotIt"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:backgroundTint="#FCECEC"
            android:text="Értem"
            android:textAllCaps="false"
            android:textColor="#1E293B"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="16dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>